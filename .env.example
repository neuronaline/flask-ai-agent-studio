# =============================================================================
# Flask AI Agent Studio - Environment Configuration
# =============================================================================
# Copy this file to .env and set your values.
# Most settings can be configured via the UI at runtime.
# =============================================================================

# FLASK_DEBUG=false

# -----------------------------------------------------------------------------
# Required: API Keys
# -----------------------------------------------------------------------------
# At least one API key is required to run the application.
DEEPSEEK_API_KEY=your-deepseek-api-key
# OPENROUTER_API_KEY=your-openrouter-api-key
# MINIMAX_API_KEY=your-minimax-api-key

# -----------------------------------------------------------------------------
# Required: Security
# -----------------------------------------------------------------------------
# IMPORTANT: Set a strong secret key in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# FLASK_SECRET_KEY=change-this-to-a-long-random-secret

# -----------------------------------------------------------------------------
# Optional: HTTPS/Proxy (uncomment if behind reverse proxy)
# -----------------------------------------------------------------------------
# FORCE_HTTPS=true
# SESSION_COOKIE_SECURE=true
# TRUST_PROXY_HEADERS=true

# -----------------------------------------------------------------------------
# Optional: Storage Paths (defaults work for most setups)
# -----------------------------------------------------------------------------
# IMAGE_STORAGE_DIR=./data/images
# DOCUMENT_STORAGE_DIR=./data/documents
# PROJECT_WORKSPACE_ROOT=./data/workspaces
# CHROMA_DB_PATH=./chroma_db

# -----------------------------------------------------------------------------
# Optional: RAG (uncomment to enable)
# -----------------------------------------------------------------------------
# RAG_ENABLED=true
# BGE_M3_DEVICE=auto   # cpu, cuda, mps, or auto
