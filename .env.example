# =============================================================================
# Flask AI Agent Studio - Environment Configuration
# =============================================================================
# Copy this file to .env and set your values.
# Most settings can be configured via the UI at runtime.
# =============================================================================

# FLASK_DEBUG=false

# -----------------------------------------------------------------------------
# Required: API Keys
# -----------------------------------------------------------------------------
# At least one API key is required to run the application.
DEEPSEEK_API_KEY=your-deepseek-api-key
# OPENROUTER_API_KEY=your-openrouter-api-key
# MINIMAX_API_KEY=your-minimax-api-key

# -----------------------------------------------------------------------------
# Required: Security
# -----------------------------------------------------------------------------
# IMPORTANT: Set a strong secret key in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# FLASK_SECRET_KEY=change-this-to-a-long-random-secret

# Login PIN (optional — leave blank to disable PIN login)
# LOGIN_PIN=your-pin-code

# -----------------------------------------------------------------------------
# Optional: OpenRouter
# -----------------------------------------------------------------------------
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_HTTP_REFERER=https://your-app.com
# OPENROUTER_APP_TITLE=Your App Name

# -----------------------------------------------------------------------------
# Optional: HTTPS/Proxy (uncomment if behind reverse proxy)
# -----------------------------------------------------------------------------
# FORCE_HTTPS=true
# SESSION_COOKIE_SECURE=true
# TRUST_PROXY_HEADERS=true
# PREFERRED_URL_SCHEME=http   # override URL scheme detection

# HSTS (uncomment to enable Strict-Transport-Security)
# SECURITY_HSTS_ENABLED=true
# SECURITY_HSTS_MAX_AGE=31536000
# SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
# SECURITY_HSTS_PRELOAD=false

# Rate limiting (Redis, optional)
# SECURITY_RATE_LIMIT_REDIS_ENABLED=false
# SECURITY_RATE_LIMIT_REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Optional: Session / Login Security
# -----------------------------------------------------------------------------
# LOGIN_SESSION_TIMEOUT_MINUTES=30
# LOGIN_MAX_FAILED_ATTEMPTS=3
# LOGIN_LOCKOUT_SECONDS=300
# LOGIN_REMEMBER_SESSION_DAYS=30

# -----------------------------------------------------------------------------
# Optional: Agent Trace Logging
# -----------------------------------------------------------------------------
# AGENT_TRACE_LOG_ENABLED=true
# AGENT_TRACE_LOG_INCLUDE_RAW=true
# AGENT_TRACE_LOG_PATH=./logs/agent-trace.log

# -----------------------------------------------------------------------------
# Optional: Application Logging
# -----------------------------------------------------------------------------
# APP_LOG_ENABLED=true
# APP_LOG_LEVEL=INFO   # DEBUG, INFO, WARNING, ERROR
# APP_LOG_PATH=./logs/app.log
# APP_LOG_MAX_BYTES=2000000
# APP_LOG_BACKUP_COUNT=5
# APP_LOG_CONSOLE_ENABLED=false

# -----------------------------------------------------------------------------
# Optional: Storage Paths (defaults work for most setups)
# -----------------------------------------------------------------------------
# IMAGE_STORAGE_DIR=./data/images
# DOCUMENT_STORAGE_DIR=./data/documents
# CHROMA_DB_PATH=./chroma_db
# PROJECT_WORKSPACE_ROOT=./data/workspaces

# -----------------------------------------------------------------------------
# Optional: Features
# -----------------------------------------------------------------------------
# OCR_ENABLED=true
# OCR_PRELOAD=true
# CONVERSATION_MEMORY_ENABLED=true
# YOUTUBE_TRANSCRIPTS_ENABLED=false
# LOW_RESOURCE_MODE=false
# SCRATCHPAD_ADMIN_EDITING_ENABLED=false

# -----------------------------------------------------------------------------
# Optional: RAG
# -----------------------------------------------------------------------------
# RAG_ENABLED=true
# BGE_M3_DEVICE=auto   # cpu, cuda, mps, or auto
# RAG_EMBED_MODEL=BAAI/bge-m3
# RAG_EMBED_BATCH_SIZE=32
# RAG_EMBED_CACHE_ENABLED=true
# RAG_EMBED_CACHE_MAX_ENTRIES=2000
# RAG_AUTO_INJECT_TOP_K=3
# RAG_SEARCH_DEFAULT_TOP_K=5
# RAG_AUTO_INJECT_THRESHOLD=0.50
# RAG_SEARCH_MIN_SIMILARITY=0.35
# RAG_CHUNK_SIZE=1800
# RAG_CHUNK_OVERLAP=250
# RAG_MAX_CHUNKS_PER_SOURCE=2
# RAG_QUERY_EXPANSION_ENABLED=true
# RAG_QUERY_EXPANSION_MAX_VARIANTS=2
# RAG_TEMPORAL_DECAY_ALPHA=0.15
# RAG_TEMPORAL_DECAY_LAMBDA=0.05
# RAG_QUERY_PARALLEL_COLLECTIONS=true
# FORCE_MEMORY_CLEANUP_AT_PERCENT=0.85
# MEMORY_CLEANUP_MIN_TOOL_RESULTS=3

# -----------------------------------------------------------------------------
# Optional: serp-scraper (web search, news, scholar, URL fetch)
# -----------------------------------------------------------------------------
# Python 3.10+, requires Google Chrome browser installed.
#
# Running on headless servers (Linux):
#   xvfb-run -a python app.py  (recommended)
#   DISPLAY=:99 python app.py
#   SERP_HEADLESS=true python app.py
#
# Documentation: https://github.com/neuronaline/serp-scraper

# Proxy Configuration
# DataImpulse Proxy (recommended) — sign up at https://dataimpulse.com
# SERP_DATAIMPULSE_GATEWAY=http://gw.dataimpulse.com:10001
# SERP_DATAIMPULSE_USER=your_username
# SERP_DATAIMPULSE_PASS=your_password

# Custom Proxies (comma-separated)
# SERP_CUSTOM_PROXIES=http://user:pass@proxy1.com:8080,socks5://proxy2.com:1080

# Proxy Strategy: "random" or "dataimpulse_first" (default: dataimpulse_first)
# SERP_PROXY_STRATEGY=dataimpulse_first

# Logging
# SERP_LOG_LEVEL=WARNING   # DEBUG, INFO, WARNING, ERROR
# SERP_DEBUG=false

# Cache
# SERP_CACHE_ENABLED=true
# SERP_CACHE_DIR=.cache/serp
# SERP_CACHE_TTL=86400     # seconds (min 60)

# Search
# SERP_DEFAULT_SOURCE=auto   # "google", "bing", or "auto"
# SERP_HEADLESS=false
# SERP_TIMEOUT=30         # seconds (5-120)

# Retry
# SERP_MAX_RETRIES=3
# SERP_RETRY_DELAY_MIN=0.5
# SERP_RETRY_DELAY_MAX=2.0
# SERP_EXPONENTIAL_BACKOFF=false

# Custom User Agent (optional)
# SERP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# -----------------------------------------------------------------------------
# Optional: Prompt / Context Tuning
# -----------------------------------------------------------------------------
# PROMPT_MAX_INPUT_TOKENS=100000
# PROMPT_RESPONSE_TOKEN_RESERVE=8000
# PROMPT_RECENT_HISTORY_MAX_TOKENS=90000
# PROMPT_SUMMARY_MAX_TOKENS=15000
# PROMPT_RAG_MAX_TOKENS=6000
# PROMPT_RAG_AUTO_MAX_TOKENS=3000
# PROMPT_TOOL_TRACE_MAX_TOKENS=2000
# PROMPT_PREFLIGHT_SUMMARY_TOKEN_COUNT=110000

# Chat Summary
# CHAT_SUMMARY_MODE=auto   # auto, conservative, never, aggressive
# CHAT_SUMMARY_MODEL=deepseek-chat
# CHAT_SUMMARY_TRIGGER_TOKEN_COUNT=120000
# CHAT_SUMMARY_STAGE_AWARE_ENABLED=false
# SUMMARY_RETRY_REDUCTION_FACTOR=0.80
# SUMMARY_SOURCE_TARGET_TOKENS=6000
# SUMMARY_RETRY_MIN_SOURCE_TOKENS=1500

# Fetch / URL Tools
# FETCH_SUMMARY_TOKEN_THRESHOLD=3500
# FETCH_SUMMARY_MAX_CHARS=8000
# FETCH_SUMMARIZE_MAX_INPUT_CHARS=80000
# FETCH_SUMMARIZE_MAX_OUTPUT_TOKENS=2400
# FETCH_SUMMARY_GENERAL_TOP_K=3
# FETCH_SUMMARY_QUERY_TOP_K=4
# FETCH_SUMMARY_EXCERPT_MAX_CHARS=500
# FETCH_RAW_TOOL_RESULT_MAX_TEXT_CHARS=24000

# Canvas
# CANVAS_PROMPT_DEFAULT_MAX_LINES=250
# CANVAS_PROMPT_DEFAULT_MAX_TOKENS=4000
# CANVAS_PROMPT_DEFAULT_MAX_CHARS=20000
# CANVAS_PROMPT_CODE_LINE_MAX_CHARS=180
# CANVAS_PROMPT_TEXT_LINE_MAX_CHARS=100
# CANVAS_EXPAND_DEFAULT_MAX_LINES=1600
# CANVAS_SCROLL_WINDOW_LINES=200

# Agent Context Compaction
# AGENT_CONTEXT_COMPACTION_THRESHOLD=0.85
# AGENT_CONTEXT_COMPACTION_KEEP_RECENT_ROUNDS=2
# PRUNING_TARGET_REDUCTION_RATIO=0.65
# PRUNING_MIN_TARGET_TOKENS=160
# PRUNE_WEIGHT_ENTROPY=0.35
# PRUNE_WEIGHT_RAG=0.30
# PRUNE_WEIGHT_STALENESS=0.25
# PRUNE_WEIGHT_TOKEN=0.10
# AGENT_TOOL_RESULT_TRANSCRIPT_MAX_CHARS=16000
